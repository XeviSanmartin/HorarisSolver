              "codi": "627",
              "index": 1,
              "nom": "Sistemes i aplicacions informàtiques"
            }
          ],
          "horaris_projectes": [
            {
              "dia": 3,
              "hora": 8
            }
          ],
          "moduls": [
            {
              "codi": "M6-0612",
              "curs": 6,
              "especialitat": 1,
              "index": 27,
              "nom": "Desenvolupament entorn client"
            }
          ],
          "moduls_coordinats": {
            "grups": [
              {
                "moduls": [
                  5,
                  12,
                  19
                ],
                "nom": "FOL DAMW"
              }
            ]
          },
          "professors": [
            {
              "7hores": false,
              "DiesLliures": false,
              "actiu": true,
              "controlable": true,
              "desiderata": [
                {
                  "dia": 1,
                  "hora": 5,
                  "tipus": 2
                }
              ],
              "especialitat": 0,
              "index": 0,
              "moduls": [
                {
                  "aula": 7,
                  "hores": 2,
                  "index": 27,
                  "subgrup": 3
                }
              ],
              "nom": "Artur Juvé",
              "nomCurt": "Artur",
              "tutorCurs": 2
            }
          ],
          "projectes": [
            37
          ]
        }
      },
      "Desiderata": {
        "properties": {
          "dia": {
            "type": "integer",
            "maximum": 4.0,
            "minimum": 0.0,
            "title": "Dia",
            "description": "0=dilluns … 4=divendres."
          },
          "hora": {
            "type": "integer",
            "maximum": 12.0,
            "minimum": 0.0,
            "title": "Hora",
            "description": "0=08:00 … 12=20:00. El solver només programa les hores 0–10."
          },
          "tipus": {
            "type": "integer",
            "maximum": 2.0,
            "minimum": 1.0,
            "title": "Tipus",
            "description": "1 = prefereix que no (soft), 2 = NO disponible (hard)."
          }
        },
        "additionalProperties": true,
        "type": "object",
        "required": [
          "dia",
          "hora",
          "tipus"
        ],
        "title": "Desiderata",
        "description": "Preferència horària d'un professor."
      },
      "DetallError": {
        "properties": {
          "error": {
            "type": "string",
            "title": "Error",
