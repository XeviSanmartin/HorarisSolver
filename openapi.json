          },
          "detall": {
            "type": "string",
            "title": "Detall",
            "description": "Excepció concreta (tipus i missatge)."
          },
          "traca": {
            "type": "string",
            "title": "Traca",
            "description": "Traça reduïda per a depuració."
          }
        },
        "type": "object",
        "required": [
          "error",
